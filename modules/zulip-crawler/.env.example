# Zulip Crawler — environment config
# Copy to .env and fill in your values

# ─── Required ────────────────────────────────────────────────────────────────
ZULIP_REALM=https://your-org.zulipchat.com
ZULIP_EMAIL=you@yourorg.com
ZULIP_API_KEY=

ANTHROPIC_API_KEY=

# ─── Optional ────────────────────────────────────────────────────────────────
LOOKBACK_HOURS=24
MAX_MSGS_PER_STREAM=200
MAX_KEPT_PER_STREAM=15
MIN_SCORE=1

# Comma-separated stream names to exclude (noise/bots)
# EXCLUDED_STREAMS=bot-alerts,random,coffee-chat

# Comma-separated partial email fragments for VIP senders
# VIP_EMAILS=ceo,manager,lead

# Write digest to a file (leave blank to print to stdout)
# OUTPUT_FILE=/path/to/palace/soul/digest.md

# Model overrides (optional — defaults are haiku for per-stream, sonnet for meta)
# HAIKU_MODEL=claude-haiku-4-5-20251001
# CLAUDE_MODEL=claude-sonnet-4-6
