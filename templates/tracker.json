{
  "owner": "[YOUR_NAME]",
  "ai": "[YOUR_AI_NAME]",
  "version": "0.1",
  "updated": "[DATE]",
  "description": "Active project tracker. Claude updates this. [YOUR_NAME] reviews it.",

  "protocol": {
    "parallel_max": 2,
    "session_format": "delta",
    "approval_required_for": ["publish", "send", "delete", "major-change"],
    "auto_proceed_for": ["draft", "research", "local-test", "internal-doc"],
    "kiss": true
  },

  "tracks": [
    {
      "id": "example-track-1",
      "name": "Example: [Project or Track Name]",
      "room": "[room-name]",
      "status": "active",
      "goal": "[What does done look like for this track?]",
      "current_step": "[Where are we right now?]",
      "next_step": "[What's the very next action?]",
      "blocker": null
    },
    {
      "id": "example-track-2",
      "name": "Example: [Another Project]",
      "room": "[room-name]",
      "status": "queued",
      "goal": "[One sentence — what are we building/doing/writing?]",
      "current_step": "[Not started yet]",
      "next_step": "[First step when we begin]",
      "blocker": "[What's in the way? Or null if nothing.]"
    }
  ],

  "closed_tracks": []
}
